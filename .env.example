# ============================================================
# new_bird - Variáveis de Ambiente
# Copie para .env e preencha os valores
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://mbird:sua_senha_aqui@localhost:5432/mbird_reports
DATABASE_ECHO=false

# --- Auth ---
JWT_SECRET=gere_um_secret_forte_aqui_minimo_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=480

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- MessageBird API ---
MESSAGEBIRD_API_KEY_LIVE=sua_api_key_aqui
MESSAGEBIRD_WORKSPACE_ID_LIVE=seu_workspace_id_aqui
MESSAGEBIRD_BASE_URL_CONVERSATIONS=https://conversations.messagebird.com/v1
MESSAGEBIRD_BASE_URL_CONTACTS=https://contacts.messagebird.com/v2
MESSAGEBIRD_HTTP_TIMEOUT=30.0
MESSAGEBIRD_TIMEZONE_OFFSET=-3

# --- Sync ---
# Perfiles: debug (15min), short (30min), hourly (1h), daily, weekly, monthly
SYNC_PROFILE=daily
SYNC_ENABLED=true

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
LOG_LEVEL=INFO
